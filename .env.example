# Agent identity (use a secure seed phrase in production)
RELOCATION_AGENT_SEED=your unique agent seed phrase here

# mainnet = need funds for Almanac contract; testnet = no funds needed (recommended for dev)
RELOCATION_NETWORK=testnet

# Agentverse: https://agentverse.ai/ — for mailbox & discovery
AGENTVERSE_API_KEY=

# ASI:One API (optional): https://asi1.ai/dashboard/api-keys — if missing or 401, plain response is used
ASI_ONE_API_KEY=

# Neighborhood API base URL (optional; uses mock if not set)
NEIGHBORHOOD_API_URL=

# Stripe (optional; enable travel booking payments when eligible)
# Get keys: https://dashboard.stripe.com/apikeys (use test keys for dev)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# URL your UI redirects to after checkout (e.g. Agentverse or your app)
STRIPE_SUCCESS_URL=https://agentverse.ai
# Checkout session validity in seconds (default 1800 = 30 min; max 86400)
# STRIPE_CHECKOUT_EXPIRES_SECONDS=3600
